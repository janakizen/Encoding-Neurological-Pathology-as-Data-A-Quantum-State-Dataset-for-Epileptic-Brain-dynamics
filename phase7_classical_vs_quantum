# FEATURE HELPERS
# ============================================================
def density_matrix_from_sequence(seq: np.ndarray) -> np.ndarray:
    seq = np.asarray(seq, dtype=float)
    seq = seq - np.mean(seq, axis=0, keepdims=True)

    rho = np.cov(seq, rowvar=False)

    if np.ndim(rho) == 0:
        rho = np.array([[float(rho)]], dtype=float)

    rho = 0.5 * (rho + rho.T)
    tr = np.trace(rho)

    if np.isclose(tr, 0):
        d = rho.shape[0]
        rho = np.eye(d) / d
    else:
        rho = rho / tr

    return rho


def von_neumann_entropy(rho: np.ndarray, eps: float = 1e-12) -> float:
    eigvals = np.linalg.eigvalsh(rho)
    eigvals = np.clip(eigvals, eps, 1.0)
    eigvals = eigvals / np.sum(eigvals)
    return float(-np.sum(eigvals * np.log2(eigvals)))


def purity(rho: np.ndarray) -> float:
    return float(np.trace(rho @ rho).real)


def transport_metrics_from_sequence(seq: np.ndarray) -> np.ndarray:
    diffs = np.diff(seq, axis=0)
    return 0.5 * np.linalg.norm(diffs, axis=1)


def classical_features_from_sequence(seq: np.ndarray) -> np.ndarray:
    seq = np.asarray(seq, dtype=float)

    mean_f = seq.mean(axis=0)
    std_f = seq.std(axis=0)
    min_f = seq.min(axis=0)
    max_f = seq.max(axis=0)
    median_f = np.median(seq, axis=0)

    delta_f = seq[-1] - seq[0]
    range_f = max_f - min_f

    vel = np.linalg.norm(np.diff(seq, axis=0), axis=1)
    vel_stats = np.array([
        vel.mean(),
        vel.std(),
        vel.min(),
        vel.max(),
    ])

    flat = seq.flatten()

    return np.concatenate([
        flat,
        mean_f,
        std_f,
        min_f,
        max_f,
        median_f,
        delta_f,
        range_f,
        vel_stats,
    ])


def quantum_native_features_from_sequence(seq: np.ndarray) -> np.ndarray:
    rho = density_matrix_from_sequence(seq)
    eigvals = np.linalg.eigvalsh(rho)
    eigvals = np.sort(eigvals)[::-1]

    ent = von_neumann_entropy(rho)
    pur = purity(rho)
    offdiag = np.sum(np.abs(rho - np.diag(np.diag(rho))))

    tm = transport_metrics_from_sequence(seq)
    tm_stats = np.array([
        tm.mean(),
        tm.std(),
        tm.min(),
        tm.max(),
    ])

    rho_flat = rho.flatten().real

    return np.concatenate([
        eigvals,
        np.array([ent, pur, offdiag]),
        tm_stats,
        rho_flat,
    ])


def build_feature_sets(X_seq: np.ndarray):
    classical = []
    quantum_native = []

    for seq in X_seq:
        classical.append(classical_features_from_sequence(seq))
        quantum_native.append(quantum_native_features_from_sequence(seq))

    return np.array(classical), np.array(quantum_native)


