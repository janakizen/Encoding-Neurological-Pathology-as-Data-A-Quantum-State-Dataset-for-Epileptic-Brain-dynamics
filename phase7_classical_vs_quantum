# DATA HELPERS
# ============================================================
def optional_downsample(X1, X2, y, max_total=None, random_state=42):
    if max_total is None or len(y) <= max_total:
        return X1, X2, y

    rng = np.random.default_rng(random_state)
    idx = rng.choice(np.arange(len(y)), size=max_total, replace=False)
    return X1[idx], X2[idx], y[idx]


def oversample_minority(X, y, random_state=42):
    """
    Random oversampling on training data only.
    """
    rng = np.random.default_rng(random_state)

    classes, counts = np.unique(y, return_counts=True)
    if len(classes) != 2:
        return X, y

    max_count = counts.max()

    X_balanced = []
    y_balanced = []

    for c in classes:
        idx = np.where(y == c)[0]
        needed = max_count - len(idx)

        X_balanced.append(X[idx])
        y_balanced.append(y[idx])

        if needed > 0:
            extra_idx = rng.choice(idx, size=needed, replace=True)
            X_balanced.append(X[extra_idx])
            y_balanced.append(y[extra_idx])

    X_out = np.vstack(X_balanced)
    y_out = np.concatenate(y_balanced)

    perm = rng.permutation(len(y_out))
    return X_out[perm], y_out[perm]


# ============================================================
# METRICS
# ============================================================
def get_scores(model, X):
    if hasattr(model, "predict_proba"):
        return model.predict_proba(X)[:, 1]
    if hasattr(model, "decision_function"):
        return model.decision_function(X)
    return None


def compute_metrics(y_true, y_pred, y_score=None):
    out = {
        "accuracy": accuracy_score(y_true, y_pred),
        "balanced_accuracy": balanced_accuracy_score(y_true, y_pred),
        "precision": precision_score(y_true, y_pred, zero_division=0),
        "recall": recall_score(y_true, y_pred, zero_division=0),
        "f1": f1_score(y_true, y_pred, zero_division=0),
    }

    if y_score is not None:
        try:
            out["roc_auc"] = roc_auc_score(y_true, y_score)
        except Exception:
            out["roc_auc"] = np.nan
    else:
        out["roc_auc"] = np.nan

    return out


def mean_cv_metric(result, key):
    vals = [fold[key] for fold in result["cv_scores"]]
    return float(np.nanmean(vals))


# ============================================================
# MODEL EVALUATION
# ============================================================
def evaluate_sklearn_model(name, model, X_train, X_test, y_train, y_test, n_splits=5):
    cv = StratifiedKFold(n_splits=n_splits, shuffle=True, random_state=RANDOM_STATE)
    cv_scores = []

    for fold_id, (tr_idx, val_idx) in enumerate(cv.split(X_train, y_train)):
        Xtr, Xval = X_train[tr_idx], X_train[val_idx]
        ytr, yval = y_train[tr_idx], y_train[val_idx]

        if BALANCE_TRAINING:
            Xtr, ytr = oversample_minority(Xtr, ytr, random_state=RANDOM_STATE + fold_id)

        model.fit(Xtr, ytr)
        pred = model.predict(Xval)
        score = get_scores(model, Xval)

        cv_scores.append(compute_metrics(yval, pred, score))

    Xfit, yfit = X_train, y_train
    if BALANCE_TRAINING:
        Xfit, yfit = oversample_minority(Xfit, yfit, random_state=RANDOM_STATE)

    model.fit(Xfit, yfit)
    test_pred = model.predict(X_test)
    test_score = get_scores(model, X_test)
    test_metrics = compute_metrics(y_test, test_pred, test_score)

    return {
        "name": name,
        "cv_scores": cv_scores,
        "test_metrics": test_metrics,
        "y_pred": test_pred,
        "y_score": test_score,
    }


def evaluate_qsvc(name, X_train_raw, X_test_raw, y_train, y_test, n_splits=5):
    def make_qsvc():
        feature_map = ZZFeatureMap(feature_dimension=QUBIT_DIM, reps=ZZ_REPS)
        qkernel = FidelityQuantumKernel(feature_map=feature_map)
        return QSVC(quantum_kernel=qkernel)

    def transform_train_test(Xtr, Xte):
        scaler = StandardScaler()
        Xtr_s = scaler.fit_transform(Xtr)
        Xte_s = scaler.transform(Xte)

        n_comp = min(QUBIT_DIM, Xtr_s.shape[1])
        pca = PCA(n_components=n_comp, random_state=RANDOM_STATE)
        Xtr_p = pca.fit_transform(Xtr_s)
        Xte_p = pca.transform(Xte_s)

        angle_scaler = MinMaxScaler(feature_range=(0, np.pi))
        Xtr_q = angle_scaler.fit_transform(Xtr_p)
        Xte_q = angle_scaler.transform(Xte_p)

        return Xtr_q, Xte_q

    cv = StratifiedKFold(n_splits=n_splits, shuffle=True, random_state=RANDOM_STATE)
    cv_scores = []

    for fold_id, (tr_idx, val_idx) in enumerate(cv.split(X_train_raw, y_train)):
        Xtr_raw, Xval_raw = X_train_raw[tr_idx], X_train_raw[val_idx]
        ytr, yval = y_train[tr_idx], y_train[val_idx]

        if BALANCE_TRAINING:
            Xtr_raw, ytr = oversample_minority(Xtr_raw, ytr, random_state=RANDOM_STATE + fold_id)

        Xtr, Xval = transform_train_test(Xtr_raw, Xval_raw)

        model = make_qsvc()
        model.fit(Xtr, ytr)

        pred = model.predict(Xval)
        score = get_scores(model, Xval)
        cv_scores.append(compute_metrics(yval, pred, score))

    Xfit_raw, yfit = X_train_raw, y_train
    if BALANCE_TRAINING:
        Xfit_raw, yfit = oversample_minority(Xfit_raw, yfit, random_state=RANDOM_STATE)

    Xfit, Xtest = transform_train_test(Xfit_raw, X_test_raw)

    model = make_qsvc()
    model.fit(Xfit, yfit)

    test_pred = model.predict(Xtest)
    test_score = get_scores(model, Xtest)
    test_metrics = compute_metrics(y_test, test_pred, test_score)

    return {
        "name": name,
        "cv_scores": cv_scores,
        "test_metrics": test_metrics,
        "y_pred": test_pred,
        "y_score": test_score,
    }


