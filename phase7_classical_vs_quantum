def plot_metric_bars(results, save_path):
    names = [r["name"] for r in results]
    bal_acc = [r["test_metrics"]["balanced_accuracy"] for r in results]
    f1s = [r["test_metrics"]["f1"] for r in results]
    aucs = [r["test_metrics"]["roc_auc"] for r in results]

    x = np.arange(len(names))
    w = 0.25

    plt.figure(figsize=(13, 6))
    plt.bar(x - w, bal_acc, width=w, label="Balanced Accuracy")
    plt.bar(x, f1s, width=w, label="F1")
    plt.bar(x + w, aucs, width=w, label="ROC-AUC")

    plt.xticks(x, names, rotation=20, ha="right")
    plt.ylim(0, 1.05)
    plt.ylabel("Score")
    plt.title("Fair Classical vs Quantum Comparison")
    plt.legend()
    plt.tight_layout()
    plt.savefig(save_path, dpi=300, bbox_inches="tight")
    plt.close()


def plot_cv_f1(results, save_path):
    plt.figure(figsize=(11, 5))
    data = [[fold["f1"] for fold in r["cv_scores"]] for r in results]
    labels = [r["name"] for r in results]

    plt.boxplot(data, tick_labels=labels, showmeans=True)
    plt.ylabel("F1")
    plt.title("Cross-Validation F1 Distribution")
    plt.xticks(rotation=20, ha="right")
    plt.tight_layout()
    plt.savefig(save_path, dpi=300, bbox_inches="tight")
    plt.close()


def plot_roc_curves(results, y_test, save_path):
    plt.figure(figsize=(8, 6))

    drawn = 0
    for r in results:
        if r["y_score"] is None:
            continue
        try:
            fpr, tpr, _ = roc_curve(y_test, r["y_score"])
            auc = r["test_metrics"]["roc_auc"]
            plt.plot(fpr, tpr, label=f"{r['name']} (AUC={auc:.3f})")
            drawn += 1
        except Exception:
            pass

    plt.plot([0, 1], [0, 1], linestyle="--")
    plt.xlabel("False Positive Rate")
    plt.ylabel("True Positive Rate")
    plt.title("ROC Curves")
    if drawn > 0:
        plt.legend()
    plt.tight_layout()
    plt.savefig(save_path, dpi=300, bbox_inches="tight")
    plt.close()


def plot_confusion_matrices(results, y_test, save_path):
    fig, axes = plt.subplots(2, 3, figsize=(14, 8))
    axes = axes.flatten()

    for ax, r in zip(axes, results):
        cm = confusion_matrix(y_test, r["y_pred"])
        ax.imshow(cm, cmap="Blues")
        ax.set_title(r["name"])
        ax.set_xlabel("Predicted")
        ax.set_ylabel("True")

        for i in range(cm.shape[0]):
            for j in range(cm.shape[1]):
                ax.text(j, i, str(cm[i, j]), ha="center", va="center")

    for ax in axes[len(results):]:
        ax.axis("off")

    plt.tight_layout()
    plt.savefig(save_path, dpi=300, bbox_inches="tight")
    plt.close()


def plot_feature_space(raw_X, qnative_X, y, save_path):
    fig, axes = plt.subplots(1, 2, figsize=(12, 5))

    for ax, X, title in zip(
        axes,
        [raw_X, qnative_X],
        ["Raw/Classical Features (PCA)", "Quantum-Native Features (PCA)"],
    ):
        Xs = StandardScaler().fit_transform(X)
        X2 = PCA(n_components=2, random_state=RANDOM_STATE).fit_transform(Xs)

        ax.scatter(X2[y == 0, 0], X2[y == 0, 1], s=12, alpha=0.6, label="Interictal")
        ax.scatter(X2[y == 1, 0], X2[y == 1, 1], s=12, alpha=0.6, label="Ictal")
        ax.set_title(title)
        ax.set_xlabel("PC1")
        ax.set_ylabel("PC2")
        ax.legend()

    plt.tight_layout()
    plt.savefig(save_path, dpi=300, bbox_inches="tight")
    plt.close()


def save_results_json(results, path):
    payload = {}
    for r in results:
        payload[r["name"]] = {
            "cv_mean_accuracy": mean_cv_metric(r, "accuracy"),
            "cv_mean_balanced_accuracy": mean_cv_metric(r, "balanced_accuracy"),
            "cv_mean_f1": mean_cv_metric(r, "f1"),
            "cv_mean_roc_auc": mean_cv_metric(r, "roc_auc"),
            "test_metrics": {
                k: (None if np.isnan(v) else float(v))
                for k, v in r["test_metrics"].items()
            },
        }

    with open(path, "w") as f:
        json.dump(payload, f, indent=2)


